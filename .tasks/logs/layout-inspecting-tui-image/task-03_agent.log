changes needed: updating `parseArgs` to add the three new options with their defaults, updating `printHelp` to document them, modifying `renderImage` to accept and use these parameters, and updating the documentation.\n\nUpdating the renderImage function... Now I'm calculating the effective scale factor that was actually applied to the canvas dimensions, which I'll need for font sizing and other rendering calculations.","signature":""}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":12349,"cache_read_input_tokens":21551,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":12349},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"fde9f51b-6888-495b-954c-98344c6e1f34","uuid":"c945b515-cf74-4fe7-9571-df701491549d"}
