{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0137HLTgr8cD1nbxfZ3TcU2f","type":"tool_result","content":"     1→#!/usr/bin/env node\n     2→/**\n     3→ * inspect_layout.js - Playwright-based layout inspector\n     4→ *\n     5→ * Navigates to a URL, walks the visible DOM, and returns a JSON tree of\n     6→ * layout-relevant nodes — those whose background or border color differs\n     7→ * from their parent's background.  The result lets an AI agent \"see\" the\n     8→ * visual box structure of the page without processing screenshots.\n     9→ *\n    10→ * Usage:\n    11→ *   node inspect_layout.js <url> [options]\n    12→ *\n    13→ * Options:\n    14→ *   --width <px>        Viewport width  (default: 1280)\n    15→ *   --height <px>       Viewport height (default: 800)\n    16→ *   --full-page         Capture the full scrollable page (default: viewport only)\n    17→ *   --max-depth <n>     Max DOM depth to recurse (default: 12)\n    18→ *   --min-size <px>     Skip nodes smaller than this in both dimensions (default: 4)\n    19→ *   --timeout <ms>      Navigation timeout in ms (default: 30000)\n    20→ *   --output <file>     Write JSON to file instead of stdout\n    21→ *   --wait-for <sel>    Wait for a CSS selector to appear before inspecting\n    22→ *   --help              Show this help\n    23→ *\n    24→ * Dependencies are installed automatically on first run into the script's own\n    25→ * directory (~/.claude/skills/layout-inspecting/scripts/node_modules).\n    26→ *\n    27→ * Exit codes:\n    28→ *   0  success\n    29→ *   1  bad arguments\n    30→ *   2  navigation/timeout error\n    31→ *   3  inspection error\n    32→ */\n    33→\n    34→const fs = require('fs');\n    35→const path = require('path');\n    36→const { spawnSync } = require('child_process');\n    37→\n    38→// ─── self-installing dependency bootstrap ───────────────────────────────────\n    39→// playwright is installed into node_modules/ beside this script so the skill\n    40→// works from any working directory without polluting the user's project.\n    41→\n    42→const SCRIPT_DIR = __dirname;\n    43→const NM = path.join(SCRIPT_DIR, 'node_modules');\n    44→const PLAYWRIGHT_ENTRY = path.join(NM, 'playwright');\n    45→\n    46→function ensureDependencies() {\n    47→  if (!fs.existsSync(PLAYWRIGHT_ENTRY)) {\n    48→    console.error('Installing playwright into skill scripts directory (first run only)...');\n    49→    const npm = spawnSync('npm', ['install', '--prefix', SCRIPT_DIR, 'playwright'], {\n    50→      stdio: 'inherit',\n    51→      encoding: 'utf8',\n    52→    });\n    53→    if (npm.status !== 0) {\n    54→      console.error('npm install failed. Make sure npm/node are available.');\n    55→      process.exit(2);\n    56→    }\n    57→  }\n    58→\n    59→  // Check whether the Chromium browser binary is present by asking playwright\n    60→  // directly via its public API.\n    61→  const chromiumBrowserPath = (() => {\n    62→    try {\n    63→      return require(PLAYWRIGHT_ENTRY).chromium.executablePath();\n    64→    } catch {\n    65→      return null;\n    66→    }\n    67→  })();\n    68→\n    69→  if (!chromiumBrowserPath || !fs.existsSync(chromiumBrowserPath)) {\n    70→    console.error('Installing Chromium browser (first run only)...');\n    71→    const install = spawnSync(\n    72→      process.execPath, // use same node binary\n    73→      [path.join(NM, '.bin', 'playwright'), 'install', 'chromium'],\n    74→      { stdio: 'inherit', encoding: 'utf8' }\n    75→    );\n    76→    if (install.status !== 0) {\n    77→      console.error('playwright install chromium failed.');\n    78→      process.exit(2);\n    79→    }\n    80→  }\n    81→}\n    82→\n    83→ensureDependencies();\n    84→\n    85→// Now safe to require playwright from the skill-local node_modules\n    86→const { chromium } = require(PLAYWRIGHT_ENTRY);\n    87→\n    88→// ─── argument parsing ───────────────────────────────────────────────────────\n    89→\n    90→function parseArgs(argv) {\n    91→  const args = argv.slice(2);\n    92→  const opts = {\n    93→    url: null,\n    94→    width: 1280,\n    95→    height: 800,\n    96→    fullPage: false,\n    97→    maxDepth: 12,\n    98→    minSize: 4,\n    99→    timeout: 30000,\n   100→    output: null,\n   101→    waitFor: null,\n   102→  };\n   103→\n   104→  for (let i = 0; i < args.length; i++) {\n   105→    const a = args[i];\n   106→    if (a === '--help') {\n   107→      printHelp();\n   108→      process.exit(0);\n   109→    } else if (a === '--full-page') {\n   110→      opts.fullPage = true;\n   111→    } else if (a === '--width') {\n   112→      opts.width = parseInt(args[++i], 10);\n   113→    } else if (a === '--height') {\n   114→      opts.height = parseInt(args[++i], 10);\n   115→    } else if (a === '--max-depth') {\n   116→      opts.maxDepth = parseInt(args[++i], 10);\n   117→    } else if (a === '--min-size') {\n   118→      opts.minSize = parseInt(args[++i], 10);\n   119→    } else if (a === '--timeout') {\n   120→      opts.timeout = parseInt(args[++i], 10);\n   121→    } else if (a === '--output') {\n   122→      opts.output = args[++i];\n   123→    } else if (a === '--wait-for') {\n   124→      opts.waitFor = args[++i];\n   125→    } else if (!a.startsWith('--')) {\n   126→      opts.url = a;\n   127→    } else {\n   128→      console.error(`Unknown option: ${a}`);\n   129→      process.exit(1);\n   130→    }\n   131→  }\n   132→\n   133→  if (!opts.url) {\n   134→    console.error('Error: URL is required.');\n   135→    printHelp();\n   136→    process.exit(1);\n   137→  }\n   138→\n   139→  return opts;\n   140→}\n   141→\n   142→function printHelp() {\n   143→  console.log(`Usage: node inspect_layout.js <url> [options]\n   144→\n   145→Options:\n   146→  --width <px>        Viewport width  (default: 1280)\n   147→  --height <px>       Viewport height (default: 800)\n   148→  --full-page         Capture the full scrollable page (default: viewport only)\n   149→  --max-depth <n>     Max DOM depth to recurse (default: 12)\n   150→  --min-size <px>     Skip nodes smaller than this in both dimensions (default: 4)\n   151→  --timeout <ms>      Navigation timeout in ms (default: 30000)\n   152→  --output <file>     Write JSON to file instead of stdout\n   153→  --wait-for <sel>    Wait for a CSS selector to appear before inspecting\n   154→  --help              Show this help`);\n   155→}\n   156→\n   157→// ─── browser-side inspection logic (serialised and eval'd in page) ──────────\n   158→\n   159→/**\n   160→ * This function runs inside the browser page via page.evaluate().\n   161→ * It receives configuration from the outer Node.js scope.\n   162→ */\n   163→function buildLayoutTree(config) {\n   164→  const { maxDepth, minSize, viewportWidth, viewportHeight, fullPage } = config;\n   165→\n   166→  // ── colour helpers ──────────────────────────────────────────────────────\n   167→\n   168→  /**\n   169→   * Parse \"rgba(r, g, b, a)\" or \"rgb(r, g, b)\" or \"transparent\" into\n   170→   * { r, g, b, a }.  Returns null for unparseable values.\n   171→   */\n   172→  function parseColor(str) {\n   173→    if (!str || str === 'transparent') return { r: 0, g: 0, b: 0, a: 0 };\n   174→    const m = str.match(/rgba?\\((\\d+),\\s*(\\d+),\\s*(\\d+)(?:,\\s*([\\d.]+))?\\)/);\n   175→    if (!m) return null;\n   176→    return {\n   177→      r: parseInt(m[1], 10),\n   178→      g: parseInt(m[2], 10),\n   179→      b: parseInt(m[3], 10),\n   180→      a: m[4] !== undefined ? parseFloat(m[4]) : 1,\n   181→    };\n   182→  }\n   183→\n   184→  function colorsEqual(a, b) {\n   185→    if (!a || !b) return false;\n   186→    // Treat fully-transparent as equal regardless of rgb\n   187→    if (a.a === 0 && b.a === 0) return true;\n   188→    return a.r === b.r && a.g === b.g && a.b === b.b && Math.abs(a.a - b.a) < 0.01;\n   189→  }\n   190→\n   191→  function isTransparent(c) {\n   192→    return !c || c.a === 0;\n   193→  }\n   194→\n   195→  /**\n   196→   * Format a color back to a compact CSS string.\n   197→   */\n   198→  function colorToString(c) {\n   199→    if (!c || c.a === 0) return 'transparent';\n   200→    if (c.a === 1) return `rgb(${c.r},${c.g},${c.b})`;\n   201→    return `rgba(${c.r},${c.g},${c.b},${c.a})`;\n   202→  }\n   203→\n   204→  // ── effective background resolution ────────────────────────────────────\n   205→\n   206→  /**\n   207→   * Walk up the ancestor chain to find the first non-transparent background,\n   208→   * starting from `el` itself.  Defaults to white (page canvas default).\n   209→   */\n   210→  function effectiveBg(el) {\n   211→    let node = el;\n   212→    while (node && node !== document.documentElement.parentElement) {\n   213→      const bg = parseColor(getComputedStyle(node).backgroundColor);\n   214→      if (bg && bg.a > 0) return bg;\n   215→      node = node.parentElement;\n   216→    }\n   217→    return { r: 255, g: 255, b: 255, a: 1 }; // browser default canvas\n   218→  }\n   219→\n   220→  // ── border visibility check ─────────────────────────────────────────────\n   221→\n   222→  /**\n   223→   * Return the first visible border color on the element that differs from\n   224→   * the given parent background, or null if no such border exists.\n   225→   */\n   226→  function visibleBorderColor(el, parentBg) {\n   227→    const style = getComputedStyle(el);\n   228→    const sides = ['Top', 'Right', 'Bottom', 'Left'];\n   229→    for (const side of sides) {\n   230→      const width = parseFloat(style[`border${side}Width`]);\n   231→      const style2 = style[`border${side}Style`];\n   232→      if (width > 0 && style2 !== 'none' && style2 !== 'hidden') {\n   233→        const color = parseColor(style[`border${side}Color`]);\n   234→        if (color && !isTransparent(color) && !colorsEqual(color, parentBg)) {\n   235→          return color;\n   236→        }\n   237→      }\n   238→    }\n   239→    return null;\n   240→  }\n   241→\n   242→  // ── tag classification helpers ──────────────────────────────────────────\n   243→\n   244→  const SKIP_TAGS = new Set([\n   245→    'SCRIPT', 'STYLE', 'NOSCRIPT', 'HEAD', 'META', 'LINK', 'TITLE',\n   246→    'TEMPLATE', 'SVG', 'PATH', 'DEFS', 'USE',\n   247→  ]);\n   248→\n   249→  const INLINE_TAGS = new Set([\n   250→    'SPAN', 'A', 'STRONG', 'EM', 'B', 'I', 'U', 'SMALL', 'LABEL',\n   251→    'ABBR', 'ACRONYM', 'CITE', 'CODE', 'KBD', 'SAMP', 'VAR', 'Q',\n   252→    'SUB', 'SUP', 'TIME', 'MARK', 'BDI', 'BDO', 'WBR',\n   253→  ]);\n   254→\n   255→  /**\n   256→   * Get a short, readable label for a node: prefer id, then aria-label,\n   257→   * then first 60 chars of innerText.\n   258→   */\n   259→  function nodeLabel(el) {\n   260→    const id = el.id ? `#${el.id}` : '';\n   261→    const cls = el.classList.length\n   262→      ? `.${Array.from(el.classList).slice(0, 3).join('.')}`\n   263→      : '';\n   264→    return `${el.tagName.toLowerCase()}${id}${cls}`;\n   265→  }\n   266→\n   267→  function textSnippet(el) {\n   268→    const text = (el.innerText || '').replace(/\\s+/g, ' ').trim();\n   269→    return text.length > 80 ? text.slice(0, 77) + '...' : text;\n   270→  }\n   271→\n   272→  // ── bounding rect helpers ───────────────────────────────────────────────\n   273→\n   274→  function rectVisible(rect) {\n   275→    if (rect.width < minSize || rect.height < minSize) return false;\n   276→    if (!fullPage) {\n   277→      // Must overlap with the viewport\n   278→      if (rect.bottom < 0 || rect.top > viewportHeight) return false;\n   279→      if (rect.right < 0 || rect.left > viewportWidth) return false;\n   280→    }\n   281→    return true;\n   282→  }\n   283→\n   284→  function roundRect(rect) {\n   285→    return {\n   286→      x: Math.round(rect.left),\n   287→      y: Math.round(rect.top),\n   288→      width: Math.round(rect.width),\n   289→      height: Math.round(rect.height),\n   290→    };\n   291→  }\n   292→\n   293→  // ── main recursive walk ─────────────────────────────────────────────────\n   294→\n   295→  /**\n   296→   * Walk the DOM from `el`, collecting nodes that visually \"stand out\" from\n   297→   * their parent's background via a different background or a visible border.\n   298→   *\n   299→   * Returns an array of node descriptor objects (children property added when\n   300→   * there are interesting descendants).\n   301→   */\n   302→  function walk(el, parentBg, depth) {\n   303→    if (depth > maxDepth) return [];\n   304→    if (SKIP_TAGS.has(el.tagName)) return [];\n   305→\n   306→    const rect = el.getBoundingClientRect();\n   307→    if (!rectVisible(rect)) return [];\n   308→\n   309→    const style = getComputedStyle(el);\n   310→    if (style.display === 'none' || style.visibility === 'hidden' || style.opacity === '0') {\n   311→      return [];\n   312→    }\n   313→\n   314→    const ownBg = parseColor(style.backgroundColor);\n   315→    const bgDiffers = ownBg && ownBg.a > 0 && !colorsEqual(ownBg, parentBg);\n   316→    const borderColor = visibleBorderColor(el, parentBg);\n   317→    const isInteresting = bgDiffers || borderColor !== null;\n   318→\n   319→    // Determine the effective bg for children: if this element has an opaque\n   320→    // background, children inherit that; otherwise they see the parent's bg.\n   321→    const childBg = (ownBg && ownBg.a > 0) ? ownBg : parentBg;\n   322→\n   323→    // Recurse into children\n   324→    const children = [];\n   325→    for (const child of el.children) {\n   326→      const subtree = walk(child, childBg, depth + 1);\n   327→      children.push(...subtree);\n   328→    }\n   329→\n   330→    if (!isInteresting) {\n   331→      // Pass-through: bubble interesting descendants up\n   332→      return children;\n   333→    }\n   334→\n   335→    // Build descriptor for this interesting node\n   336→    const descriptor = {\n   337→      label: nodeLabel(el),\n   338→      tag: el.tagName.toLowerCase(),\n   339→      role: el.getAttribute('role') || undefined,\n   340→      rect: roundRect(rect),\n   341→      background: bgDiffers ? colorToString(ownBg) : colorToString(parentBg),\n   342→    };\n   343→\n   344→    if (borderColor) {\n   345→      descriptor.border = colorToString(borderColor);\n   346→    }\n   347→\n   348→    const snippet = textSnippet(el);\n   349→    if (snippet) descriptor.text = snippet;\n   350→\n   351→    if (children.length > 0) {\n   352→      descriptor.children = children;\n   353→    }\n   354→\n   355→    return [descriptor];\n   356→  }\n   357→\n   358→  // ── document root ───────────────────────────────────────────────────────\n   359→\n   360→  const htmlEl = document.documentElement;\n   361→  const htmlStyle = getComputedStyle(htmlEl);\n   362→  const bodyStyle = getComputedStyle(document.body);\n   363→\n   364→  // Resolve the canvas/root background (html or body, whichever is opaque)\n   365→  let rootBg =\n   366→    parseColor(htmlStyle.backgroundColor) ||\n   367→    parseColor(bodyStyle.backgroundColor) ||\n   368→    { r: 255, g: 255, b: 255, a: 1 };\n   369→\n   370→  if (rootBg.a === 0) rootBg = { r: 255, g: 255, b: 255, a: 1 };\n   371→\n   372→  const docRect = {\n   373→    x: 0,\n   374→    y: 0,\n   375→    width: fullPage ? Math.max(document.documentElement.scrollWidth, viewportWidth) : viewportWidth,\n   376→    height: fullPage ? Math.max(document.documentElement.scrollHeight, viewportHeight) : viewportHeight,\n   377→  };\n   378→\n   379→  const children = [];\n   380→  for (const child of document.body.children) {\n   381→    const subtree = walk(child, rootBg, 1);\n   382→    children.push(...subtree);\n   383→  }\n   384→\n   385→  return {\n   386→    label: 'document',\n   387→    tag: 'document',\n   388→    rect: docRect,\n   389→    background: colorToString(rootBg),\n   390→    children: children.length > 0 ? children : undefined,\n   391→  };\n   392→}\n   393→\n   394→// ─── main ───────────────────────────────────────────────────────────────────\n   395→\n   396→async function main() {\n   397→  const opts = parseArgs(process.argv);\n   398→\n   399→  let browser;\n   400→  try {\n   401→    browser = await chromium.launch({ headless: true });\n   402→  } catch (err) {\n   403→    console.error(`Failed to launch browser: ${err.message}`);\n   404→    console.error('Make sure Playwright and Chromium are installed:');\n   405→    console.error('  npm install playwright');\n   406→    console.error('  npx playwright install chromium');\n   407→    process.exit(2);\n   408→  }\n   409→\n   410→  try {\n   411→    const context = await browser.newContext({\n   412→      viewport: { width: opts.width, height: opts.height },\n   413→    });\n   414→    const page = await context.newPage();\n   415→\n   416→    // Navigate\n   417→    try {\n   418→      await page.goto(opts.url, {\n   419→        waitUntil: 'networkidle',\n   420→        timeout: opts.timeout,\n   421→      });\n   422→    } catch (err) {\n   423→      console.error(`Navigation failed: ${err.message}`);\n   424→      process.exit(2);\n   425→    }\n   426→\n   427→    // Optional selector wait\n   428→    if (opts.waitFor) {\n   429→      try {\n   430→        await page.waitForSelector(opts.waitFor, { timeout: opts.timeout });\n   431→      } catch (err) {\n   432→        console.error(`Timed out waiting for selector \"${opts.waitFor}\": ${err.message}`);\n   433→        process.exit(2);\n   434→      }\n   435→    }\n   436→\n   437→    // Run inspection inside the page\n   438→    let tree;\n   439→    try {\n   440→      tree = await page.evaluate(buildLayoutTree, {\n   441→        maxDepth: opts.maxDepth,\n   442→        minSize: opts.minSize,\n   443→        viewportWidth: opts.width,\n   444→        viewportHeight: opts.height,\n   445→        fullPage: opts.fullPage,\n   446→      });\n   447→    } catch (err) {\n   448→      console.error(`Layout inspection failed: ${err.message}`);\n   449→      process.exit(3);\n   450→    }\n   451→\n   452→    const result = {\n   453→      url: page.url(),\n   454→      viewport: { width: opts.width, height: opts.height },\n   455→      fullPage: opts.fullPage,\n   456→      capturedAt: new Date().toISOString(),\n   457→      layout: tree,\n   458→    };\n   459→\n   460→    const json = JSON.stringify(result, null, 2);\n   461→\n   462→    if (opts.output) {\n   463→      fs.writeFileSync(opts.output, json, 'utf8');\n   464→      console.error(`Layout written to ${opts.output}`);\n   465→    } else {\n   466→      process.stdout.write(json + '\\n');\n   467→    }\n   468→  } finally {\n   469→    await browser.close();\n   470→  }\n   471→}\n   472→\n   473→main().catch((err) => {\n   474→  console.error(`Unexpected error: ${err.message}`);\n   475→  process.exit(3);\n   476→});\n   477→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"9230af59-663e-42ce-8313-c2b8db0a74f8","uuid":"e42e1c0d-5251-4772-90ee-0ec2bb5dc905","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/skills/layout-inspecting/scripts/inspect_layout.js","content":"#!/usr/bin/env node\n/**\n * inspect_layout.js - Playwright-based layout inspector\n *\n * Navigates to a URL, walks the visible DOM, and returns a JSON tree of\n * layout-relevant nodes — those whose background or border color differs\n * from their parent's background.  The result lets an AI agent \"see\" the\n * visual box structure of the page without processing screenshots.\n *\n * Usage:\n *   node inspect_layout.js <url> [options]\n *\n * Options:\n *   --width <px>        Viewport width  (default: 1280)\n *   --height <px>       Viewport height (default: 800)\n *   --full-page         Capture the full scrollable page (default: viewport only)\n *   --max-depth <n>     Max DOM depth to recurse (default: 12)\n *   --min-size <px>     Skip nodes smaller than this in both dimensions (default: 4)\n *   --timeout <ms>      Navigation timeout in ms (default: 30000)\n *   --output <file>     Write JSON to file instead of stdout\n *   --wait-for <sel>    Wait for a CSS selector to appear before inspecting\n *   --help              Show this help\n *\n * Dependencies are installed automatically on first run into the script's own\n * directory (~/.claude/skills/layout-inspecting/scripts/node_modules).\n *\n * Exit codes:\n *   0  success\n *   1  bad arguments\n *   2  navigation/timeout error\n *   3  inspection error\n */\n\nconst fs = require('fs');\nconst path = require('path');\nconst { spawnSync } = require('child_process');\n\n// ─── self-installing dependency bootstrap ───────────────────────────────────\n// playwright is installed into node_modules/ beside this script so the skill\n// works from any working directory without polluting the user's project.\n\nconst SCRIPT_DIR = __dirname;\nconst NM = path.join(SCRIPT_DIR, 'node_modules');\nconst PLAYWRIGHT_ENTRY = path.join(NM, 'playwright');\n\nfunction ensureDependencies() {\n  if (!fs.existsSync(PLAYWRIGHT_ENTRY)) {\n    console.error('Installing playwright into skill scripts directory (first run only)...');\n    const npm = spawnSync('npm', ['install', '--prefix', SCRIPT_DIR, 'playwright'], {\n      stdio: 'inherit',\n      encoding: 'utf8',\n    });\n    if (npm.status !== 0) {\n      console.error('npm install failed. Make sure npm/node are available.');\n      process.exit(2);\n    }\n  }\n\n  // Check whether the Chromium browser binary is present by asking playwright\n  // directly via its public API.\n  const chromiumBrowserPath = (() => {\n    try {\n      return require(PLAYWRIGHT_ENTRY).chromium.executablePath();\n    } catch {\n      return null;\n    }\n  })();\n\n  if (!chromiumBrowserPath || !fs.existsSync(chromiumBrowserPath)) {\n    console.error('Installing Chromium browser (first run only)...');\n    const install = spawnSync(\n      process.execPath, // use same node binary\n      [path.join(NM, '.bin', 'playwright'), 'install', 'chromium'],\n      { stdio: 'inherit', encoding: 'utf8' }\n    );\n    if (install.status !== 0) {\n      console.error('playwright install chromium failed.');\n      process.exit(2);\n    }\n  }\n}\n\nensureDependencies();\n\n// Now safe to require playwright from the skill-local node_modules\nconst { chromium } = require(PLAYWRIGHT_ENTRY);\n\n// ─── argument parsing ───────────────────────────────────────────────────────\n\nfunction parseArgs(argv) {\n  const args = argv.slice(2);\n  const opts = {\n    url: null,\n    width: 1280,\n    height: 800,\n    fullPage: false,\n    maxDepth: 12,\n    minSize: 4,\n    timeout: 30000,\n    output: null,\n    waitFor: null,\n  };\n\n  for (let i = 0; i < args.length; i++) {\n    const a = args[i];\n    if (a === '--help') {\n      printHelp();\n      process.exit(0);\n    } else if (a === '--full-page') {\n      opts.fullPage = true;\n    } else if (a === '--width') {\n      opts.width = parseInt(args[++i], 10);\n    } else if (a === '--height') {\n      opts.height = parseInt(args[++i], 10);\n    } else if (a === '--max-depth') {\n      opts.maxDepth = parseInt(args[++i], 10);\n    } else if (a === '--min-size') {\n      opts.minSize = parseInt(args[++i], 10);\n    } else if (a === '--timeout') {\n      opts.timeout = parseInt(args[++i], 10);\n    } else if (a === '--output') {\n      opts.output = args[++i];\n    } else if (a === '--wait-for') {\n      opts.waitFor = args[++i];\n    } else if (!a.startsWith('--')) {\n      opts.url = a;\n    } else {\n      console.error(`Unknown option: ${a}`);\n      process.exit(1);\n    }\n  }\n\n  if (!opts.url) {\n    console.error('Error: URL is required.');\n    printHelp();\n    process.exit(1);\n  }\n\n  return opts;\n}\n\nfunction printHelp() {\n  console.log(`Usage: node inspect_layout.js <url> [options]\n\nOptions:\n  --width <px>        Viewport width  (default: 1280)\n  --height <px>       Viewport height (default: 800)\n  --full-page         Capture the full scrollable page (default: viewport only)\n  --max-depth <n>     Max DOM depth to recurse (default: 12)\n  --min-size <px>     Skip nodes smaller than this in both dimensions (default: 4)\n  --timeout <ms>      Navigation timeout in ms (default: 30000)\n  --output <file>     Write JSON to file instead of stdout\n  --wait-for <sel>    Wait for a CSS selector to appear before inspecting\n  --help              Show this help`);\n}\n\n// ─── browser-side inspection logic (serialised and eval'd in page) ──────────\n\n/**\n * This function runs inside the browser page via page.evaluate().\n * It receives configuration from the outer Node.js scope.\n */\nfunction buildLayoutTree(config) {\n  const { maxDepth, minSize, viewportWidth, viewportHeight, fullPage } = config;\n\n  // ── colour helpers ──────────────────────────────────────────────────────\n\n  /**\n   * Parse \"rgba(r, g, b, a)\" or \"rgb(r, g, b)\" or \"transparent\" into\n   * { r, g, b, a }.  Returns null for unparseable values.\n   */\n  function parseColor(str) {\n    if (!str || str === 'transparent') return { r: 0, g: 0, b: 0, a: 0 };\n    const m = str.match(/rgba?\\((\\d+),\\s*(\\d+),\\s*(\\d+)(?:,\\s*([\\d.]+))?\\)/);\n    if (!m) return null;\n    return {\n      r: parseInt(m[1], 10),\n      g: parseInt(m[2], 10),\n      b: parseInt(m[3], 10),\n      a: m[4] !== undefined ? parseFloat(m[4]) : 1,\n    };\n  }\n\n  function colorsEqual(a, b) {\n    if (!a || !b) return false;\n    // Treat fully-transparent as equal regardless of rgb\n    if (a.a === 0 && b.a === 0) return true;\n    return a.r === b.r && a.g === b.g && a.b === b.b && Math.abs(a.a - b.a) < 0.01;\n  }\n\n  function isTransparent(c) {\n    return !c || c.a === 0;\n  }\n\n  /**\n   * Format a color back to a compact CSS string.\n   */\n  function colorToString(c) {\n    if (!c || c.a === 0) return 'transparent';\n    if (c.a === 1) return `rgb(${c.r},${c.g},${c.b})`;\n    return `rgba(${c.r},${c.g},${c.b},${c.a})`;\n  }\n\n  // ── effective background resolution ────────────────────────────────────\n\n  /**\n   * Walk up the ancestor chain to find the first non-transparent background,\n   * starting from `el` itself.  Defaults to white (page canvas default).\n   */\n  function effectiveBg(el) {\n    let node = el;\n    while (node && node !== document.documentElement.parentElement) {\n      const bg = parseColor(getComputedStyle(node).backgroundColor);\n      if (bg && bg.a > 0) return bg;\n      node = node.parentElement;\n    }\n    return { r: 255, g: 255, b: 255, a: 1 }; // browser default canvas\n  }\n\n  // ── border visibility check ─────────────────────────────────────────────\n\n  /**\n   * Return the first visible border color on the element that differs from\n   * the given parent background, or null if no such border exists.\n   */\n  function visibleBorderColor(el, parentBg) {\n    const style = getComputedStyle(el);\n    const sides = ['Top', 'Right', 'Bottom', 'Left'];\n    for (const side of sides) {\n      const width = parseFloat(style[`border${side}Width`]);\n      const style2 = style[`border${side}Style`];\n      if (width > 0 && style2 !== 'none' && style2 !== 'hidden') {\n        const color = parseColor(style[`border${side}Color`]);\n        if (color && !isTransparent(color) && !colorsEqual(color, parentBg)) {\n          return color;\n        }\n      }\n    }\n    return null;\n  }\n\n  // ── tag classification helpers ──────────────────────────────────────────\n\n  const SKIP_TAGS = new Set([\n    'SCRIPT', 'STYLE', 'NOSCRIPT', 'HEAD', 'META', 'LINK', 'TITLE',\n    'TEMPLATE', 'SVG', 'PATH', 'DEFS', 'USE',\n  ]);\n\n  const INLINE_TAGS = new Set([\n    'SPAN', 'A', 'STRONG', 'EM', 'B', 'I', 'U', 'SMALL', 'LABEL',\n    'ABBR', 'ACRONYM', 'CITE', 'CODE', 'KBD', 'SAMP', 'VAR', 'Q',\n    'SUB', 'SUP', 'TIME', 'MARK', 'BDI', 'BDO', 'WBR',\n  ]);\n\n  /**\n   * Get a short, readable label for a node: prefer id, then aria-label,\n   * then first 60 chars of innerText.\n   */\n  function nodeLabel(el) {\n    const id = el.id ? `#${el.id}` : '';\n    const cls = el.classList.length\n      ? `.${Array.from(el.classList).slice(0, 3).join('.')}`\n      : '';\n    return `${el.tagName.toLowerCase()}${id}${cls}`;\n  }\n\n  function textSnippet(el) {\n    const text = (el.innerText || '').replace(/\\s+/g, ' ').trim();\n    return text.length > 80 ? text.slice(0, 77) + '...' : text;\n  }\n\n  // ── bounding rect helpers ───────────────────────────────────────────────\n\n  function rectVisible(rect) {\n    if (rect.width < minSize || rect.height < minSize) return false;\n    if (!fullPage) {\n      // Must overlap with the viewport\n      if (rect.bottom < 0 || rect.top > viewportHeight) return false;\n      if (rect.right < 0 || rect.left > viewportWidth) return false;\n    }\n    return true;\n  }\n\n  function roundRect(rect) {\n    return {\n      x: Math.round(rect.left),\n      y: Math.round(rect.top),\n      width: Math.round(rect.width),\n      height: Math.round(rect.height),\n    };\n  }\n\n  // ── main recursive walk ─────────────────────────────────────────────────\n\n  /**\n   * Walk the DOM from `el`, collecting nodes that visually \"stand out\" from\n   * their parent's background via a different background or a visible border.\n   *\n   * Returns an array of node descriptor objects (children property added when\n   * there are interesting descendants).\n   */\n  function walk(el, parentBg, depth) {\n    if (depth > maxDepth) return [];\n    if (SKIP_TAGS.has(el.tagName)) return [];\n\n    const rect = el.getBoundingClientRect();\n    if (!rectVisible(rect)) return [];\n\n    const style = getComputedStyle(el);\n    if (style.display === 'none' || style.visibility === 'hidden' || style.opacity === '0') {\n      return [];\n    }\n\n    const ownBg = parseColor(style.backgroundColor);\n    const bgDiffers = ownBg && ownBg.a > 0 && !colorsEqual(ownBg, parentBg);\n    const borderColor = visibleBorderColor(el, parentBg);\n    const isInteresting = bgDiffers || borderColor !== null;\n\n    // Determine the effective bg for children: if this element has an opaque\n    // background, children inherit that; otherwise they see the parent's bg.\n    const childBg = (ownBg && ownBg.a > 0) ? ownBg : parentBg;\n\n    // Recurse into children\n    const children = [];\n    for (const child of el.children) {\n      const subtree = walk(child, childBg, depth + 1);\n      children.push(...subtree);\n    }\n\n    if (!isInteresting) {\n      // Pass-through: bubble interesting descendants up\n      return children;\n    }\n\n    // Build descriptor for this interesting node\n    const descriptor = {\n      label: nodeLabel(el),\n      tag: el.tagName.toLowerCase(),\n      role: el.getAttribute('role') || undefined,\n      rect: roundRect(rect),\n      background: bgDiffers ? colorToString(ownBg) : colorToString(parentBg),\n    };\n\n    if (borderColor) {\n      descriptor.border = colorToString(borderColor);\n    }\n\n    const snippet = textSnippet(el);\n    if (snippet) descriptor.text = snippet;\n\n    if (children.length > 0) {\n      descriptor.children = children;\n    }\n\n    return [descriptor];\n  }\n\n  // ── document root ───────────────────────────────────────────────────────\n\n  const htmlEl = document.documentElement;\n  const htmlStyle = getComputedStyle(htmlEl);\n  const bodyStyle = getComputedStyle(document.body);\n\n  // Resolve the canvas/root background (html or body, whichever is opaque)\n  let rootBg =\n    parseColor(htmlStyle.backgroundColor) ||\n    parseColor(bodyStyle.backgroundColor) ||\n    { r: 255, g: 255, b: 255, a: 1 };\n\n  if (rootBg.a === 0) rootBg = { r: 255, g: 255, b: 255, a: 1 };\n\n  const docRect = {\n    x: 0,\n    y: 0,\n    width: fullPage ? Math.max(document.documentElement.scrollWidth, viewportWidth) : viewportWidth,\n    height: fullPage ? Math.max(document.documentElement.scrollHeight, viewportHeight) : viewportHeight,\n  };\n\n  const children = [];\n  for (const child of document.body.children) {\n    const subtree = walk(child, rootBg, 1);\n    children.push(...subtree);\n  }\n\n  return {\n    label: 'document',\n    tag: 'document',\n    rect: docRect,\n    background: colorToString(rootBg),\n    children: children.length > 0 ? children : undefined,\n  };\n}\n\n// ─── main ───────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const opts = parseArgs(process.argv);\n\n  let browser;\n  try {\n    browser = await chromium.launch({ headless: true });\n  } catch (err) {\n    console.error(`Failed to launch browser: ${err.message}`);\n    console.error('Make sure Playwright and Chromium are installed:');\n    console.error('  npm install playwright');\n    console.error('  npx playwright install chromium');\n    process.exit(2);\n  }\n\n  try {\n    const context = await browser.newContext({\n      viewport: { width: opts.width, height: opts.height },\n    });\n    const page = await context.newPage();\n\n    // Navigate\n    try {\n      await page.goto(opts.url, {\n        waitUntil: 'networkidle',\n        timeout: opts.timeout,\n      });\n    } catch (err) {\n      console.error(`Navigation failed: ${err.message}`);\n      process.exit(2);\n    }\n\n    // Optional selector wait\n    if (opts.waitFor) {\n      try {\n        await page.waitForSelector(opts.waitFor, { timeout: opts.timeout });\n      } catch (err) {\n        console.error(`Timed out waiting for selector \"${opts.waitFor}\": ${err.message}`);\n        process.exit(2);\n      }\n    }\n\n    // Run inspection inside the page\n    let tree;\n    try {\n      tree = await page.evaluate(buildLayoutTree, {\n        maxDepth: opts.maxDepth,\n        minSize: opts.minSize,\n        viewportWidth: opts.width,\n        viewportHeight: opts.height,\n        fullPage: opts.fullPage,\n      });\n    } catch (err) {\n      console.error(`Layout inspection failed: ${err.message}`);\n      process.exit(3);\n    }\n\n    const result = {\n      url: page.url(),\n      viewport: { width: opts.width, height: opts.height },\n      fullPage: opts.fullPage,\n      capturedAt: new Date().toISOString(),\n      layout: tree,\n    };\n\n    const json = JSON.stringify(result, null, 2);\n\n    if (opts.output) {\n      fs.writeFileSync(opts.output, json, 'utf8');\n      console.error(`Layout written to ${opts.output}`);\n    } else {\n      process.stdout.write(json + '\\n');\n    }\n  } finally {\n    await browser.close();\n  }\n}\n\nmain().catch((err) => {\n  console.error(`Unexpected error: ${err.message}`);\n  process.exit(3);\n});\n","numLines":477,"startLine":1,"totalLines":477}}}
