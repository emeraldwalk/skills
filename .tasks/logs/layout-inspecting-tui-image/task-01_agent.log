{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NQ1y75fFyKDNpi8jEqDLid","type":"tool_result","content":"     1→#!/usr/bin/env node\n     2→/**\n     3→ * inspect_layout.js - Playwright-based layout inspector\n     4→ *\n     5→ * Navigates to a URL, walks the visible DOM, and returns a JSON tree of\n     6→ * layout-relevant nodes — those whose background or border color differs\n     7→ * from their parent's background.  The result lets an AI agent \"see\" the\n     8→ * visual box structure of the page without processing screenshots.\n     9→ *\n    10→ * Usage:\n    11→ *   node inspect_layout.js <url> [options]\n    12→ *\n    13→ * Options:\n    14→ *   --width <px>        Viewport width  (default: 1280)\n    15→ *   --height <px>       Viewport height (default: 800)\n    16→ *   --full-page         Capture the full scrollable page (default: viewport only)\n    17→ *   --max-depth <n>     Max DOM depth to recurse (default: 12)\n    18→ *   --min-size <px>     Skip nodes smaller than this in both dimensions (default: 4)\n    19→ *   --timeout <ms>      Navigation timeout in ms (default: 30000)\n    20→ *   --output <file>     Write JSON to file instead of stdout\n    21→ *   --wait-for <sel>    Wait for a CSS selector to appear before inspecting\n    22→ *   --help              Show this help\n    23→ *\n    24→ * Dependencies are installed automatically on first run into the script's own\n    25→ * directory (~/.claude/skills/layout-inspecting/scripts/node_modules).\n    26→ *\n    27→ * Exit codes:\n    28→ *   0  success\n    29→ *   1  bad arguments\n    30→ *   2  navigation/timeout error\n    31→ *   3  inspection error\n    32→ */\n    33→\n    34→const fs = require('fs');\n    35→const path = require('path');\n    36→const { spawnSync } = require('child_process');\n    37→\n    38→// ─── self-installing dependency bootstrap ───────────────────────────────────\n    39→// playwright is installed into node_modules/ beside this script so the skill\n    40→// works from any working directory without polluting the user's project.\n    41→\n    42→const SCRIPT_DIR = __dirname;\n    43→const NM = path.join(SCRIPT_DIR, 'node_modules');\n    44→const PLAYWRIGHT_ENTRY = path.join(NM, 'playwright');\n    45→\n    46→function ensureDependencies() {\n    47→  if (!fs.existsSync(PLAYWRIGHT_ENTRY)) {\n    48→    console.error('Installing playwright into skill scripts directory (first run only)...');\n    49→    const npm = spawnSync('npm', ['install', '--prefix', SCRIPT_DIR, 'playwright'], {\n    50→      stdio: 'inherit',\n    51→      encoding: 'utf8',\n    52→    });\n    53→    if (npm.status !== 0) {\n    54→      console.error('npm install failed. Make sure npm/node are available.');\n    55→      process.exit(2);\n    56→    }\n    57→  }\n    58→\n    59→  // Check whether the Chromium browser binary is present by asking playwright\n    60→  // directly via its public API.\n    61→  const chromiumBrowserPath = (() => {\n    62→    try {\n    63→      return require(PLAYWRIGHT_ENTRY).chromium.executablePath();\n    64→    } catch {\n    65→      return null;\n    66→    }\n    67→  })();\n    68→\n    69→  if (!chromiumBrowserPath || !fs.existsSync(chromiumBrowserPath)) {\n    70→    console.error('Installing Chromium browser (first run only)...');\n    71→    const install = spawnSync(\n    72→      process.execPath, // use same node binary\n    73→      [path.join(NM, '.bin', 'playwright'), 'install', 'chromium'],\n    74→      { stdio: 'inherit', encoding: 'utf8' }\n    75→    );\n    76→    if (install.status !== 0) {\n    77→      console.error('playwright install chromium failed.');\n    78→      process.exit(2);\n    79→    }\n    80→  }\n    81→\n    82→  // Also ensure blessed is available for the --tui mode\n    83→  const blessedEntry = path.join(NM, 'blessed');\n    84→  if (!fs.existsSync(blessedEntry)) {\n    85→    console.error('Installing blessed into skill scripts directory (first run only)...');\n    86→    const blessedInstall = spawnSync('npm', ['install', '--prefix', SCRIPT_DIR, 'blessed'], {\n    87→      stdio: 'inherit',\n    88→      encoding: 'utf8',\n    89→    });\n    90→    if (blessedInstall.status !== 0) {\n    91→      console.error('npm install blessed failed.');\n    92→      process.exit(2);\n    93→    }\n    94→  }\n    95→}\n    96→\n    97→ensureDependencies();\n    98→\n    99→// Now safe to require playwright from the skill-local node_modules\n   100→const { chromium } = require(PLAYWRIGHT_ENTRY);\n   101→\n   102→// ─── argument parsing ───────────────────────────────────────────────────────\n   103→\n   104→function parseArgs(argv) {\n   105→  const args = argv.slice(2);\n   106→  const opts = {\n   107→    url: null,\n   108→    width: 1280,\n   109→    height: 800,\n   110→    fullPage: false,\n   111→    maxDepth: 12,\n   112→    minSize: 4,\n   113→    timeout: 30000,\n   114→    output: null,\n   115→    waitFor: null,\n   116→    tui: false,\n   117→  };\n   118→\n   119→  for (let i = 0; i < args.length; i++) {\n   120→    const a = args[i];\n   121→    if (a === '--help') {\n   122→      printHelp();\n   123→      process.exit(0);\n   124→    } else if (a === '--full-page') {\n   125→      opts.fullPage = true;\n   126→    } else if (a === '--width') {\n   127→      opts.width = parseInt(args[++i], 10);\n   128→    } else if (a === '--height') {\n   129→      opts.height = parseInt(args[++i], 10);\n   130→    } else if (a === '--max-depth') {\n   131→      opts.maxDepth = parseInt(args[++i], 10);\n   132→    } else if (a === '--min-size') {\n   133→      opts.minSize = parseInt(args[++i], 10);\n   134→    } else if (a === '--timeout') {\n   135→      opts.timeout = parseInt(args[++i], 10);\n   136→    } else if (a === '--output') {\n   137→      opts.output = args[++i];\n   138→    } else if (a === '--wait-for') {\n   139→      opts.waitFor = args[++i];\n   140→    } else if (a === '--tui') {\n   141→      opts.tui = true;\n   142→    } else if (!a.startsWith('--')) {\n   143→      opts.url = a;\n   144→    } else {\n   145→      console.error(`Unknown option: ${a}`);\n   146→      process.exit(1);\n   147→    }\n   148→  }\n   149→\n   150→  if (!opts.url) {\n   151→    console.error('Error: URL is required.');\n   152→    printHelp();\n   153→    process.exit(1);\n   154→  }\n   155→\n   156→  return opts;\n   157→}\n   158→\n   159→function printHelp() {\n   160→  console.log(`Usage: node inspect_layout.js <url> [options]\n   161→\n   162→Options:\n   163→  --width <px>        Viewport width  (default: 1280)\n   164→  --height <px>       Viewport height (default: 800)\n   165→  --full-page         Capture the full scrollable page (default: viewport only)\n   166→  --max-depth <n>     Max DOM depth to recurse (default: 12)\n   167→  --min-size <px>     Skip nodes smaller than this in both dimensions (default: 4)\n   168→  --timeout <ms>      Navigation timeout in ms (default: 30000)\n   169→  --output <file>     Write JSON to file instead of stdout (incompatible with --tui)\n   170→  --wait-for <sel>    Wait for a CSS selector to appear before inspecting\n   171→  --tui               Launch interactive terminal UI showing a spatial wireframe\n   172→  --help              Show this help`);\n   173→}\n   174→\n   175→// ─── browser-side inspection logic (serialised and eval'd in page) ──────────\n   176→\n   177→/**\n   178→ * This function runs inside the browser page via page.evaluate().\n   179→ * It receives configuration from the outer Node.js scope.\n   180→ */\n   181→function buildLayoutTree(config) {\n   182→  const { maxDepth, minSize, viewportWidth, viewportHeight, fullPage } = config;\n   183→\n   184→  // ── colour helpers ──────────────────────────────────────────────────────\n   185→\n   186→  /**\n   187→   * Parse \"rgba(r, g, b, a)\" or \"rgb(r, g, b)\" or \"transparent\" into\n   188→   * { r, g, b, a }.  Returns null for unparseable values.\n   189→   */\n   190→  function parseColor(str) {\n   191→    if (!str || str === 'transparent') return { r: 0, g: 0, b: 0, a: 0 };\n   192→    const m = str.match(/rgba?\\((\\d+),\\s*(\\d+),\\s*(\\d+)(?:,\\s*([\\d.]+))?\\)/);\n   193→    if (!m) return null;\n   194→    return {\n   195→      r: parseInt(m[1], 10),\n   196→      g: parseInt(m[2], 10),\n   197→      b: parseInt(m[3], 10),\n   198→      a: m[4] !== undefined ? parseFloat(m[4]) : 1,\n   199→    };\n   200→  }\n   201→\n   202→  function colorsEqual(a, b) {\n   203→    if (!a || !b) return false;\n   204→    // Treat fully-transparent as equal regardless of rgb\n   205→    if (a.a === 0 && b.a === 0) return true;\n   206→    return a.r === b.r && a.g === b.g && a.b === b.b && Math.abs(a.a - b.a) < 0.01;\n   207→  }\n   208→\n   209→  function isTransparent(c) {\n   210→    return !c || c.a === 0;\n   211→  }\n   212→\n   213→  /**\n   214→   * Format a color back to a compact CSS string.\n   215→   */\n   216→  function colorToString(c) {\n   217→    if (!c || c.a === 0) return 'transparent';\n   218→    if (c.a === 1) return `rgb(${c.r},${c.g},${c.b})`;\n   219→    return `rgba(${c.r},${c.g},${c.b},${c.a})`;\n   220→  }\n   221→\n   222→  // ── effective background resolution ────────────────────────────────────\n   223→\n   224→  /**\n   225→   * Walk up the ancestor chain to find the first non-transparent background,\n   226→   * starting from `el` itself.  Defaults to white (page canvas default).\n   227→   */\n   228→  function effectiveBg(el) {\n   229→    let node = el;\n   230→    while (node && node !== document.documentElement.parentElement) {\n   231→      const bg = parseColor(getComputedStyle(node).backgroundColor);\n   232→      if (bg && bg.a > 0) return bg;\n   233→      node = node.parentElement;\n   234→    }\n   235→    return { r: 255, g: 255, b: 255, a: 1 }; // browser default canvas\n   236→  }\n   237→\n   238→  // ── border visibility check ─────────────────────────────────────────────\n   239→\n   240→  /**\n   241→   * Return the first visible border color on the element that differs from\n   242→   * the given parent background, or null if no such border exists.\n   243→   */\n   244→  function visibleBorderColor(el, parentBg) {\n   245→    const style = getComputedStyle(el);\n   246→    const sides = ['Top', 'Right', 'Bottom', 'Left'];\n   247→    for (const side of sides) {\n   248→      const width = parseFloat(style[`border${side}Width`]);\n   249→      const style2 = style[`border${side}Style`];\n   250→      if (width > 0 && style2 !== 'none' && style2 !== 'hidden') {\n   251→        const color = parseColor(style[`border${side}Color`]);\n   252→        if (color && !isTransparent(color) && !colorsEqual(color, parentBg)) {\n   253→          return color;\n   254→        }\n   255→      }\n   256→    }\n   257→    return null;\n   258→  }\n   259→\n   260→  // ── tag classification helpers ──────────────────────────────────────────\n   261→\n   262→  const SKIP_TAGS = new Set([\n   263→    'SCRIPT', 'STYLE', 'NOSCRIPT', 'HEAD', 'META', 'LINK', 'TITLE',\n   264→    'TEMPLATE', 'SVG', 'PATH', 'DEFS', 'USE',\n   265→  ]);\n   266→\n   267→  const INLINE_TAGS = new Set([\n   268→    'SPAN', 'A', 'STRONG', 'EM', 'B', 'I', 'U', 'SMALL', 'LABEL',\n   269→    'ABBR', 'ACRONYM', 'CITE', 'CODE', 'KBD', 'SAMP', 'VAR', 'Q',\n   270→    'SUB', 'SUP', 'TIME', 'MARK', 'BDI', 'BDO', 'WBR',\n   271→  ]);\n   272→\n   273→  /**\n   274→   * Get a short, readable label for a node: prefer id, then aria-label,\n   275→   * then first 60 chars of innerText.\n   276→   */\n   277→  function nodeLabel(el) {\n   278→    const id = el.id ? `#${el.id}` : '';\n   279→    const cls = el.classList.length\n   280→      ? `.${Array.from(el.classList).slice(0, 3).join('.')}`\n   281→      : '';\n   282→    return `${el.tagName.toLowerCase()}${id}${cls}`;\n   283→  }\n   284→\n   285→  function textSnippet(el) {\n   286→    const text = (el.innerText || '').replace(/\\s+/g, ' ').trim();\n   287→    return text.length > 80 ? text.slice(0, 77) + '...' : text;\n   288→  }\n   289→\n   290→  // ── bounding rect helpers ───────────────────────────────────────────────\n   291→\n   292→  function rectVisible(rect) {\n   293→    if (rect.width < minSize || rect.height < minSize) return false;\n   294→    if (!fullPage) {\n   295→      // Must overlap with the viewport\n   296→      if (rect.bottom < 0 || rect.top > viewportHeight) return false;\n   297→      if (rect.right < 0 || rect.left > viewportWidth) return false;\n   298→    }\n   299→    return true;\n   300→  }\n   301→\n   302→  function roundRect(rect) {\n   303→    return {\n   304→      x: Math.round(rect.left),\n   305→      y: Math.round(rect.top),\n   306→      width: Math.round(rect.width),\n   307→      height: Math.round(rect.height),\n   308→    };\n   309→  }\n   310→\n   311→  // ── main recursive walk ─────────────────────────────────────────────────\n   312→\n   313→  /**\n   314→   * Walk the DOM from `el`, collecting nodes that visually \"stand out\" from\n   315→   * their parent's background via a different background or a visible border.\n   316→   *\n   317→   * Returns an array of node descriptor objects (children property added when\n   318→   * there are interesting descendants).\n   319→   */\n   320→  function walk(el, parentBg, depth) {\n   321→    if (depth > maxDepth) return [];\n   322→    if (SKIP_TAGS.has(el.tagName)) return [];\n   323→\n   324→    const rect = el.getBoundingClientRect();\n   325→    if (!rectVisible(rect)) return [];\n   326→\n   327→    const style = getComputedStyle(el);\n   328→    if (style.display === 'none' || style.visibility === 'hidden' || style.opacity === '0') {\n   329→      return [];\n   330→    }\n   331→\n   332→    const ownBg = parseColor(style.backgroundColor);\n   333→    const bgDiffers = ownBg && ownBg.a > 0 && !colorsEqual(ownBg, parentBg);\n   334→    const borderColor = visibleBorderColor(el, parentBg);\n   335→    const isInteresting = bgDiffers || borderColor !== null;\n   336→\n   337→    // Determine the effective bg for children: if this element has an opaque\n   338→    // background, children inherit that; otherwise they see the parent's bg.\n   339→    const childBg = (ownBg && ownBg.a > 0) ? ownBg : parentBg;\n   340→\n   341→    // Recurse into children\n   342→    const children = [];\n   343→    for (const child of el.children) {\n   344→      const subtree = walk(child, childBg, depth + 1);\n   345→      children.push(...subtree);\n   346→    }\n   347→\n   348→    if (!isInteresting) {\n   349→      // Pass-through: bubble interesting descendants up\n   350→      return children;\n   351→    }\n   352→\n   353→    // Build descriptor for this interesting node\n   354→    const descriptor = {\n   355→      label: nodeLabel(el),\n   356→      tag: el.tagName.toLowerCase(),\n   357→      role: el.getAttribute('role') || undefined,\n   358→      rect: roundRect(rect),\n   359→      background: bgDiffers ? colorToString(ownBg) : colorToString(parentBg),\n   360→    };\n   361→\n   362→    if (borderColor) {\n   363→      descriptor.border = colorToString(borderColor);\n   364→    }\n   365→\n   366→    const snippet = textSnippet(el);\n   367→    if (snippet) descriptor.text = snippet;\n   368→\n   369→    if (children.length > 0) {\n   370→      descriptor.children = children;\n   371→    }\n   372→\n   373→    return [descriptor];\n   374→  }\n   375→\n   376→  // ── document root ───────────────────────────────────────────────────────\n   377→\n   378→  const htmlEl = document.documentElement;\n   379→  const htmlStyle = getComputedStyle(htmlEl);\n   380→  const bodyStyle = getComputedStyle(document.body);\n   381→\n   382→  // Resolve the canvas/root background (html or body, whichever is opaque)\n   383→  let rootBg =\n   384→    parseColor(htmlStyle.backgroundColor) ||\n   385→    parseColor(bodyStyle.backgroundColor) ||\n   386→    { r: 255, g: 255, b: 255, a: 1 };\n   387→\n   388→  if (rootBg.a === 0) rootBg = { r: 255, g: 255, b: 255, a: 1 };\n   389→\n   390→  const docRect = {\n   391→    x: 0,\n   392→    y: 0,\n   393→    width: fullPage ? Math.max(document.documentElement.scrollWidth, viewportWidth) : viewportWidth,\n   394→    height: fullPage ? Math.max(document.documentElement.scrollHeight, viewportHeight) : viewportHeight,\n   395→  };\n   396→\n   397→  const children = [];\n   398→  for (const child of document.body.children) {\n   399→    const subtree = walk(child, rootBg, 1);\n   400→    children.push(...subtree);\n   401→  }\n   402→\n   403→  return {\n   404→    label: 'document',\n   405→    tag: 'document',\n   406→    rect: docRect,\n   407→    background: colorToString(rootBg),\n   408→    children: children.length > 0 ? children : undefined,\n   409→  };\n   410→}\n   411→\n   412→// ─── TUI renderer ───────────────────────────────────────────────────────────\n   413→\n   414→/**\n   415→ * Render the layout result as an interactive blessed terminal UI.\n   416→ * Each node is drawn as a box at its proportional position, sized\n   417→ * proportionally to the terminal window.  Tree order (root first) ensures\n   418→ * children paint on top of parents.\n   419→ */\n   420→function renderTui(result) {\n   421→  const blessed = require(path.join(NM, 'blessed'));\n   422→\n   423→  const screen = blessed.screen({\n   424→    smartCSR: true,\n   425→    title: `Layout: ${result.url}`,\n   426→    fullUnicode: true,\n   427→  });\n   428→\n   429→  const termCols = screen.width;\n   430→  const termRows = screen.height;\n   431→\n   432→  const docRect = result.layout.rect;\n   433→  const pageW = Math.max(docRect.width, 1);\n   434→  const pageH = Math.max(docRect.height, 1);\n   435→\n   436→  // Parse \"rgb(r,g,b)\" / \"rgba(r,g,b,a)\" into {r,g,b} or null\n   437→  function parseRgb(colorStr) {\n   438→    if (!colorStr || colorStr === 'transparent') return null;\n   439→    const m = colorStr.match(/rgba?\\((\\d+),\\s*(\\d+),\\s*(\\d+)/);\n   440→    return m ? { r: +m[1], g: +m[2], b: +m[3] } : null;\n   441→  }\n   442→\n   443→  // Convert RGB to \"#rrggbb\" hex for blessed style\n   444→  function toHex(r, g, b) {\n   445→    return '#' + [r, g, b].map(v => v.toString(16).padStart(2, '0')).join('');\n   446→  }\n   447→\n   448→  // Choose black or white foreground based on background luminance\n   449→  function contrastFg(color) {\n   450→    if (!color) return '#ffffff';\n   451→    const lum = 0.299 * color.r + 0.587 * color.g + 0.114 * color.b;\n   452→    return lum > 128 ? '#000000' : '#ffffff';\n   453→  }\n   454→\n   455→  // Flatten tree in DFS pre-order so parents are drawn before children\n   456→  function flattenTree(node, out) {\n   457→    out.push(node);\n   458→    if (node.children) {\n   459→      for (const child of node.children) flattenTree(child, out);\n   460→    }\n   461→  }\n   462→\n   463→  const nodes = [];\n   464→  flattenTree(result.layout, nodes);\n   465→\n   466→  for (const node of nodes) {\n   467→    const { x, y, width, height } = node.rect;\n   468→\n   469→    // Scale pixel coords to terminal character cells\n   470→    const left = Math.round(x / pageW * termCols);\n   471→    const top  = Math.round(y / pageH * termRows);\n   472→    const w    = Math.max(3, Math.round(width  / pageW * termCols));\n   473→    const h    = Math.max(2, Math.round(height / pageH * termRows));\n   474→\n   475→    const color = parseRgb(node.background);\n   476→    const bgHex = color ? toHex(color.r, color.g, color.b) : '#1a1a1a';\n   477→    const fgHex = contrastFg(color);\n   478→\n   479→    const box = blessed.box({\n   480→      left,\n   481→      top,\n   482→      width: w,\n   483→      height: h,\n   484→      content: node.label || '',\n   485→      tags: false,\n   486→      border: { type: 'line' },\n   487→      style: {\n   488→        bg: bgHex,\n   489→        fg: fgHex,\n   490→        border: { fg: fgHex },\n   491→      },\n   492→    });\n   493→\n   494→    screen.append(box);\n   495→  }\n   496→\n   497→  // Help overlay in bottom-right corner\n   498→  const helpText = ' q:quit ';\n   499→  const helpBox = blessed.box({\n   500→    bottom: 0,\n   501→    right: 0,\n   502→    width: helpText.length,\n   503→    height: 1,\n   504→    content: helpText,\n   505→    style: { fg: 'white', bg: 'black' },\n   506→  });\n   507→  screen.append(helpBox);\n   508→\n   509→  screen.key(['q', 'Q', 'C-c'], () => {\n   510→    screen.destroy();\n   511→    process.exit(0);\n   512→  });\n   513→\n   514→  screen.render();\n   515→}\n   516→\n   517→// ─── main ───────────────────────────────────────────────────────────────────\n   518→\n   519→async function main() {\n   520→  const opts = parseArgs(process.argv);\n   521→\n   522→  if (opts.tui && opts.output) {\n   523→    console.error('Error: --tui and --output are incompatible. Use one or the other.');\n   524→    process.exit(1);\n   525→  }\n   526→\n   527→  let browser;\n   528→  try {\n   529→    browser = await chromium.launch({ headless: true });\n   530→  } catch (err) {\n   531→    console.error(`Failed to launch browser: ${err.message}`);\n   532→    console.error('Make sure Playwright and Chromium are installed:');\n   533→    console.error('  npm install playwright');\n   534→    console.error('  npx playwright install chromium');\n   535→    process.exit(2);\n   536→  }\n   537→\n   538→  try {\n   539→    const context = await browser.newContext({\n   540→      viewport: { width: opts.width, height: opts.height },\n   541→    });\n   542→    const page = await context.newPage();\n   543→\n   544→    // Navigate\n   545→    try {\n   546→      await page.goto(opts.url, {\n   547→        waitUntil: 'networkidle',\n   548→        timeout: opts.timeout,\n   549→      });\n   550→    } catch (err) {\n   551→      console.error(`Navigation failed: ${err.message}`);\n   552→      process.exit(2);\n   553→    }\n   554→\n   555→    // Optional selector wait\n   556→    if (opts.waitFor) {\n   557→      try {\n   558→        await page.waitForSelector(opts.waitFor, { timeout: opts.timeout });\n   559→      } catch (err) {\n   560→        console.error(`Timed out waiting for selector \"${opts.waitFor}\": ${err.message}`);\n   561→        process.exit(2);\n   562→      }\n   563→    }\n   564→\n   565→    // Run inspection inside the page\n   566→    let tree;\n   567→    try {\n   568→      tree = await page.evaluate(buildLayoutTree, {\n   569→        maxDepth: opts.maxDepth,\n   570→        minSize: opts.minSize,\n   571→        viewportWidth: opts.width,\n   572→        viewportHeight: opts.height,\n   573→        fullPage: opts.fullPage,\n   574→      });\n   575→    } catch (err) {\n   576→      console.error(`Layout inspection failed: ${err.message}`);\n   577→      process.exit(3);\n   578→    }\n   579→\n   580→    const result = {\n   581→      url: page.url(),\n   582→      viewport: { width: opts.width, height: opts.height },\n   583→      fullPage: opts.fullPage,\n   584→      capturedAt: new Date().toISOString(),\n   585→      layout: tree,\n   586→    };\n   587→\n   588→    if (opts.tui) {\n   589→      renderTui(result);\n   590→      // renderTui sets up the blessed event loop; process stays alive until 'q'\n   591→    } else {\n   592→      const json = JSON.stringify(result, null, 2);\n   593→      if (opts.output) {\n   594→        fs.writeFileSync(opts.output, json, 'utf8');\n   595→        console.error(`Layout written to ${opts.output}`);\n   596→      } else {\n   597→        process.stdout.write(json + '\\n');\n   598→      }\n   599→    }\n   600→  } finally {\n   601→    await browser.close();\n   602→  }\n   603→}\n   604→\n   605→main().catch((err) => {\n   606→  console.error(`Unexpected error: ${err.message}`);\n   607→  process.exit(3);\n   608→});\n   609→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"9230af59-663e-42ce-8313-c2b8db0a74f8","uuid":"f4fba31f-d21f-465b-a179-969a08ee4f2f","tool_use_result":{"type":"text","file":{"filePath":"/workspaces/skills/layout-inspecting/scripts/inspect_layout.js","content":"#!/usr/bin/env node\n/**\n * inspect_layout.js - Playwright-based layout inspector\n *\n * Navigates to a URL, walks the visible DOM, and returns a JSON tree of\n * layout-relevant nodes — those whose background or border color differs\n * from their parent's background.  The result lets an AI agent \"see\" the\n * visual box structure of the page without processing screenshots.\n *\n * Usage:\n *   node inspect_layout.js <url> [options]\n *\n * Options:\n *   --width <px>        Viewport width  (default: 1280)\n *   --height <px>       Viewport height (default: 800)\n *   --full-page         Capture the full scrollable page (default: viewport only)\n *   --max-depth <n>     Max DOM depth to recurse (default: 12)\n *   --min-size <px>     Skip nodes smaller than this in both dimensions (default: 4)\n *   --timeout <ms>      Navigation timeout in ms (default: 30000)\n *   --output <file>     Write JSON to file instead of stdout\n *   --wait-for <sel>    Wait for a CSS selector to appear before inspecting\n *   --help              Show this help\n *\n * Dependencies are installed automatically on first run into the script's own\n * directory (~/.claude/skills/layout-inspecting/scripts/node_modules).\n *\n * Exit codes:\n *   0  success\n *   1  bad arguments\n *   2  navigation/timeout error\n *   3  inspection error\n */\n\nconst fs = require('fs');\nconst path = require('path');\nconst { spawnSync } = require('child_process');\n\n// ─── self-installing dependency bootstrap ───────────────────────────────────\n// playwright is installed into node_modules/ beside this script so the skill\n// works from any working directory without polluting the user's project.\n\nconst SCRIPT_DIR = __dirname;\nconst NM = path.join(SCRIPT_DIR, 'node_modules');\nconst PLAYWRIGHT_ENTRY = path.join(NM, 'playwright');\n\nfunction ensureDependencies() {\n  if (!fs.existsSync(PLAYWRIGHT_ENTRY)) {\n    console.error('Installing playwright into skill scripts directory (first run only)...');\n    const npm = spawnSync('npm', ['install', '--prefix', SCRIPT_DIR, 'playwright'], {\n      stdio: 'inherit',\n      encoding: 'utf8',\n    });\n    if (npm.status !== 0) {\n      console.error('npm install failed. Make sure npm/node are available.');\n      process.exit(2);\n    }\n  }\n\n  // Check whether the Chromium browser binary is present by asking playwright\n  // directly via its public API.\n  const chromiumBrowserPath = (() => {\n    try {\n      return require(PLAYWRIGHT_ENTRY).chromium.executablePath();\n    } catch {\n      return null;\n    }\n  })();\n\n  if (!chromiumBrowserPath || !fs.existsSync(chromiumBrowserPath)) {\n    console.error('Installing Chromium browser (first run only)...');\n    const install = spawnSync(\n      process.execPath, // use same node binary\n      [path.join(NM, '.bin', 'playwright'), 'install', 'chromium'],\n      { stdio: 'inherit', encoding: 'utf8' }\n    );\n    if (install.status !== 0) {\n      console.error('playwright install chromium failed.');\n      process.exit(2);\n    }\n  }\n\n  // Also ensure blessed is available for the --tui mode\n  const blessedEntry = path.join(NM, 'blessed');\n  if (!fs.existsSync(blessedEntry)) {\n    console.error('Installing blessed into skill scripts directory (first run only)...');\n    const blessedInstall = spawnSync('npm', ['install', '--prefix', SCRIPT_DIR, 'blessed'], {\n      stdio: 'inherit',\n      encoding: 'utf8',\n    });\n    if (blessedInstall.status !== 0) {\n      console.error('npm install blessed failed.');\n      process.exit(2);\n    }\n  }\n}\n\nensureDependencies();\n\n// Now safe to require playwright from the skill-local node_modules\nconst { chromium } = require(PLAYWRIGHT_ENTRY);\n\n// ─── argument parsing ───────────────────────────────────────────────────────\n\nfunction parseArgs(argv) {\n  const args = argv.slice(2);\n  const opts = {\n    url: null,\n    width: 1280,\n    height: 800,\n    fullPage: false,\n    maxDepth: 12,\n    minSize: 4,\n    timeout: 30000,\n    output: null,\n    waitFor: null,\n    tui: false,\n  };\n\n  for (let i = 0; i < args.length; i++) {\n    const a = args[i];\n    if (a === '--help') {\n      printHelp();\n      process.exit(0);\n    } else if (a === '--full-page') {\n      opts.fullPage = true;\n    } else if (a === '--width') {\n      opts.width = parseInt(args[++i], 10);\n    } else if (a === '--height') {\n      opts.height = parseInt(args[++i], 10);\n    } else if (a === '--max-depth') {\n      opts.maxDepth = parseInt(args[++i], 10);\n    } else if (a === '--min-size') {\n      opts.minSize = parseInt(args[++i], 10);\n    } else if (a === '--timeout') {\n      opts.timeout = parseInt(args[++i], 10);\n    } else if (a === '--output') {\n      opts.output = args[++i];\n    } else if (a === '--wait-for') {\n      opts.waitFor = args[++i];\n    } else if (a === '--tui') {\n      opts.tui = true;\n    } else if (!a.startsWith('--')) {\n      opts.url = a;\n    } else {\n      console.error(`Unknown option: ${a}`);\n      process.exit(1);\n    }\n  }\n\n  if (!opts.url) {\n    console.error('Error: URL is required.');\n    printHelp();\n    process.exit(1);\n  }\n\n  return opts;\n}\n\nfunction printHelp() {\n  console.log(`Usage: node inspect_layout.js <url> [options]\n\nOptions:\n  --width <px>        Viewport width  (default: 1280)\n  --height <px>       Viewport height (default: 800)\n  --full-page         Capture the full scrollable page (default: viewport only)\n  --max-depth <n>     Max DOM depth to recurse (default: 12)\n  --min-size <px>     Skip nodes smaller than this in both dimensions (default: 4)\n  --timeout <ms>      Navigation timeout in ms (default: 30000)\n  --output <file>     Write JSON to file instead of stdout (incompatible with --tui)\n  --wait-for <sel>    Wait for a CSS selector to appear before inspecting\n  --tui               Launch interactive terminal UI showing a spatial wireframe\n  --help              Show this help`);\n}\n\n// ─── browser-side inspection logic (serialised and eval'd in page) ──────────\n\n/**\n * This function runs inside the browser page via page.evaluate().\n * It receives configuration from the outer Node.js scope.\n */\nfunction buildLayoutTree(config) {\n  const { maxDepth, minSize, viewportWidth, viewportHeight, fullPage } = config;\n\n  // ── colour helpers ──────────────────────────────────────────────────────\n\n  /**\n   * Parse \"rgba(r, g, b, a)\" or \"rgb(r, g, b)\" or \"transparent\" into\n   * { r, g, b, a }.  Returns null for unparseable values.\n   */\n  function parseColor(str) {\n    if (!str || str === 'transparent') return { r: 0, g: 0, b: 0, a: 0 };\n    const m = str.match(/rgba?\\((\\d+),\\s*(\\d+),\\s*(\\d+)(?:,\\s*([\\d.]+))?\\)/);\n    if (!m) return null;\n    return {\n      r: parseInt(m[1], 10),\n      g: parseInt(m[2], 10),\n      b: parseInt(m[3], 10),\n      a: m[4] !== undefined ? parseFloat(m[4]) : 1,\n    };\n  }\n\n  function colorsEqual(a, b) {\n    if (!a || !b) return false;\n    // Treat fully-transparent as equal regardless of rgb\n    if (a.a === 0 && b.a === 0) return true;\n    return a.r === b.r && a.g === b.g && a.b === b.b && Math.abs(a.a - b.a) < 0.01;\n  }\n\n  function isTransparent(c) {\n    return !c || c.a === 0;\n  }\n\n  /**\n   * Format a color back to a compact CSS string.\n   */\n  function colorToString(c) {\n    if (!c || c.a === 0) return 'transparent';\n    if (c.a === 1) return `rgb(${c.r},${c.g},${c.b})`;\n    return `rgba(${c.r},${c.g},${c.b},${c.a})`;\n  }\n\n  // ── effective background resolution ────────────────────────────────────\n\n  /**\n   * Walk up the ancestor chain to find the first non-transparent background,\n   * starting from `el` itself.  Defaults to white (page canvas default).\n   */\n  function effectiveBg(el) {\n    let node = el;\n    while (node && node !== document.documentElement.parentElement) {\n      const bg = parseColor(getComputedStyle(node).backgroundColor);\n      if (bg && bg.a > 0) return bg;\n      node = node.parentElement;\n    }\n    return { r: 255, g: 255, b: 255, a: 1 }; // browser default canvas\n  }\n\n  // ── border visibility check ─────────────────────────────────────────────\n\n  /**\n   * Return the first visible border color on the element that differs from\n   * the given parent background, or null if no such border exists.\n   */\n  function visibleBorderColor(el, parentBg) {\n    const style = getComputedStyle(el);\n    const sides = ['Top', 'Right', 'Bottom', 'Left'];\n    for (const side of sides) {\n      const width = parseFloat(style[`border${side}Width`]);\n      const style2 = style[`border${side}Style`];\n      if (width > 0 && style2 !== 'none' && style2 !== 'hidden') {\n        const color = parseColor(style[`border${side}Color`]);\n        if (color && !isTransparent(color) && !colorsEqual(color, parentBg)) {\n          return color;\n        }\n      }\n    }\n    return null;\n  }\n\n  // ── tag classification helpers ──────────────────────────────────────────\n\n  const SKIP_TAGS = new Set([\n    'SCRIPT', 'STYLE', 'NOSCRIPT', 'HEAD', 'META', 'LINK', 'TITLE',\n    'TEMPLATE', 'SVG', 'PATH', 'DEFS', 'USE',\n  ]);\n\n  const INLINE_TAGS = new Set([\n    'SPAN', 'A', 'STRONG', 'EM', 'B', 'I', 'U', 'SMALL', 'LABEL',\n    'ABBR', 'ACRONYM', 'CITE', 'CODE', 'KBD', 'SAMP', 'VAR', 'Q',\n    'SUB', 'SUP', 'TIME', 'MARK', 'BDI', 'BDO', 'WBR',\n  ]);\n\n  /**\n   * Get a short, readable label for a node: prefer id, then aria-label,\n   * then first 60 chars of innerText.\n   */\n  function nodeLabel(el) {\n    const id = el.id ? `#${el.id}` : '';\n    const cls = el.classList.length\n      ? `.${Array.from(el.classList).slice(0, 3).join('.')}`\n      : '';\n    return `${el.tagName.toLowerCase()}${id}${cls}`;\n  }\n\n  function textSnippet(el) {\n    const text = (el.innerText || '').replace(/\\s+/g, ' ').trim();\n    return text.length > 80 ? text.slice(0, 77) + '...' : text;\n  }\n\n  // ── bounding rect helpers ───────────────────────────────────────────────\n\n  function rectVisible(rect) {\n    if (rect.width < minSize || rect.height < minSize) return false;\n    if (!fullPage) {\n      // Must overlap with the viewport\n      if (rect.bottom < 0 || rect.top > viewportHeight) return false;\n      if (rect.right < 0 || rect.left > viewportWidth) return false;\n    }\n    return true;\n  }\n\n  function roundRect(rect) {\n    return {\n      x: Math.round(rect.left),\n      y: Math.round(rect.top),\n      width: Math.round(rect.width),\n      height: Math.round(rect.height),\n    };\n  }\n\n  // ── main recursive walk ─────────────────────────────────────────────────\n\n  /**\n   * Walk the DOM from `el`, collecting nodes that visually \"stand out\" from\n   * their parent's background via a different background or a visible border.\n   *\n   * Returns an array of node descriptor objects (children property added when\n   * there are interesting descendants).\n   */\n  function walk(el, parentBg, depth) {\n    if (depth > maxDepth) return [];\n    if (SKIP_TAGS.has(el.tagName)) return [];\n\n    const rect = el.getBoundingClientRect();\n    if (!rectVisible(rect)) return [];\n\n    const style = getComputedStyle(el);\n    if (style.display === 'none' || style.visibility === 'hidden' || style.opacity === '0') {\n      return [];\n    }\n\n    const ownBg = parseColor(style.backgroundColor);\n    const bgDiffers = ownBg && ownBg.a > 0 && !colorsEqual(ownBg, parentBg);\n    const borderColor = visibleBorderColor(el, parentBg);\n    const isInteresting = bgDiffers || borderColor !== null;\n\n    // Determine the effective bg for children: if this element has an opaque\n    // background, children inherit that; otherwise they see the parent's bg.\n    const childBg = (ownBg && ownBg.a > 0) ? ownBg : parentBg;\n\n    // Recurse into children\n    const children = [];\n    for (const child of el.children) {\n      const subtree = walk(child, childBg, depth + 1);\n      children.push(...subtree);\n    }\n\n    if (!isInteresting) {\n      // Pass-through: bubble interesting descendants up\n      return children;\n    }\n\n    // Build descriptor for this interesting node\n    const descriptor = {\n      label: nodeLabel(el),\n      tag: el.tagName.toLowerCase(),\n      role: el.getAttribute('role') || undefined,\n      rect: roundRect(rect),\n      background: bgDiffers ? colorToString(ownBg) : colorToString(parentBg),\n    };\n\n    if (borderColor) {\n      descriptor.border = colorToString(borderColor);\n    }\n\n    const snippet = textSnippet(el);\n    if (snippet) descriptor.text = snippet;\n\n    if (children.length > 0) {\n      descriptor.children = children;\n    }\n\n    return [descriptor];\n  }\n\n  // ── document root ───────────────────────────────────────────────────────\n\n  const htmlEl = document.documentElement;\n  const htmlStyle = getComputedStyle(htmlEl);\n  const bodyStyle = getComputedStyle(document.body);\n\n  // Resolve the canvas/root background (html or body, whichever is opaque)\n  let rootBg =\n    parseColor(htmlStyle.backgroundColor) ||\n    parseColor(bodyStyle.backgroundColor) ||\n    { r: 255, g: 255, b: 255, a: 1 };\n\n  if (rootBg.a === 0) rootBg = { r: 255, g: 255, b: 255, a: 1 };\n\n  const docRect = {\n    x: 0,\n    y: 0,\n    width: fullPage ? Math.max(document.documentElement.scrollWidth, viewportWidth) : viewportWidth,\n    height: fullPage ? Math.max(document.documentElement.scrollHeight, viewportHeight) : viewportHeight,\n  };\n\n  const children = [];\n  for (const child of document.body.children) {\n    const subtree = walk(child, rootBg, 1);\n    children.push(...subtree);\n  }\n\n  return {\n    label: 'document',\n    tag: 'document',\n    rect: docRect,\n    background: colorToString(rootBg),\n    children: children.length > 0 ? children : undefined,\n  };\n}\n\n// ─── TUI renderer ───────────────────────────────────────────────────────────\n\n/**\n * Render the layout result as an interactive blessed terminal UI.\n * Each node is drawn as a box at its proportional position, sized\n * proportionally to the terminal window.  Tree order (root first) ensures\n * children paint on top of parents.\n */\nfunction renderTui(result) {\n  const blessed = require(path.join(NM, 'blessed'));\n\n  const screen = blessed.screen({\n    smartCSR: true,\n    title: `Layout: ${result.url}`,\n    fullUnicode: true,\n  });\n\n  const termCols = screen.width;\n  const termRows = screen.height;\n\n  const docRect = result.layout.rect;\n  const pageW = Math.max(docRect.width, 1);\n  const pageH = Math.max(docRect.height, 1);\n\n  // Parse \"rgb(r,g,b)\" / \"rgba(r,g,b,a)\" into {r,g,b} or null\n  function parseRgb(colorStr) {\n    if (!colorStr || colorStr === 'transparent') return null;\n    const m = colorStr.match(/rgba?\\((\\d+),\\s*(\\d+),\\s*(\\d+)/);\n    return m ? { r: +m[1], g: +m[2], b: +m[3] } : null;\n  }\n\n  // Convert RGB to \"#rrggbb\" hex for blessed style\n  function toHex(r, g, b) {\n    return '#' + [r, g, b].map(v => v.toString(16).padStart(2, '0')).join('');\n  }\n\n  // Choose black or white foreground based on background luminance\n  function contrastFg(color) {\n    if (!color) return '#ffffff';\n    const lum = 0.299 * color.r + 0.587 * color.g + 0.114 * color.b;\n    return lum > 128 ? '#000000' : '#ffffff';\n  }\n\n  // Flatten tree in DFS pre-order so parents are drawn before children\n  function flattenTree(node, out) {\n    out.push(node);\n    if (node.children) {\n      for (const child of node.children) flattenTree(child, out);\n    }\n  }\n\n  const nodes = [];\n  flattenTree(result.layout, nodes);\n\n  for (const node of nodes) {\n    const { x, y, width, height } = node.rect;\n\n    // Scale pixel coords to terminal character cells\n    const left = Math.round(x / pageW * termCols);\n    const top  = Math.round(y / pageH * termRows);\n    const w    = Math.max(3, Math.round(width  / pageW * termCols));\n    const h    = Math.max(2, Math.round(height / pageH * termRows));\n\n    const color = parseRgb(node.background);\n    const bgHex = color ? toHex(color.r, color.g, color.b) : '#1a1a1a';\n    const fgHex = contrastFg(color);\n\n    const box = blessed.box({\n      left,\n      top,\n      width: w,\n      height: h,\n      content: node.label || '',\n      tags: false,\n      border: { type: 'line' },\n      style: {\n        bg: bgHex,\n        fg: fgHex,\n        border: { fg: fgHex },\n      },\n    });\n\n    screen.append(box);\n  }\n\n  // Help overlay in bottom-right corner\n  const helpText = ' q:quit ';\n  const helpBox = blessed.box({\n    bottom: 0,\n    right: 0,\n    width: helpText.length,\n    height: 1,\n    content: helpText,\n    style: { fg: 'white', bg: 'black' },\n  });\n  screen.append(helpBox);\n\n  screen.key(['q', 'Q', 'C-c'], () => {\n    screen.destroy();\n    process.exit(0);\n  });\n\n  screen.render();\n}\n\n// ─── main ───────────────────────────────────────────────────────────────────\n\nasync function main() {\n  const opts = parseArgs(process.argv);\n\n  if (opts.tui && opts.output) {\n    console.error('Error: --tui and --output are incompatible. Use one or the other.');\n    process.exit(1);\n  }\n\n  let browser;\n  try {\n    browser = await chromium.launch({ headless: true });\n  } catch (err) {\n    console.error(`Failed to launch browser: ${err.message}`);\n    console.error('Make sure Playwright and Chromium are installed:');\n    console.error('  npm install playwright');\n    console.error('  npx playwright install chromium');\n    process.exit(2);\n  }\n\n  try {\n    const context = await browser.newContext({\n      viewport: { width: opts.width, height: opts.height },\n    });\n    const page = await context.newPage();\n\n    // Navigate\n    try {\n      await page.goto(opts.url, {\n        waitUntil: 'networkidle',\n        timeout: opts.timeout,\n      });\n    } catch (err) {\n      console.error(`Navigation failed: ${err.message}`);\n      process.exit(2);\n    }\n\n    // Optional selector wait\n    if (opts.waitFor) {\n      try {\n        await page.waitForSelector(opts.waitFor, { timeout: opts.timeout });\n      } catch (err) {\n        console.error(`Timed out waiting for selector \"${opts.waitFor}\": ${err.message}`);\n        process.exit(2);\n      }\n    }\n\n    // Run inspection inside the page\n    let tree;\n    try {\n      tree = await page.evaluate(buildLayoutTree, {\n        maxDepth: opts.maxDepth,\n        minSize: opts.minSize,\n        viewportWidth: opts.width,\n        viewportHeight: opts.height,\n        fullPage: opts.fullPage,\n      });\n    } catch (err) {\n      console.error(`Layout inspection failed: ${err.message}`);\n      process.exit(3);\n    }\n\n    const result = {\n      url: page.url(),\n      viewport: { width: opts.width, height: opts.height },\n      fullPage: opts.fullPage,\n      capturedAt: new Date().toISOString(),\n      layout: tree,\n    };\n\n    if (opts.tui) {\n      renderTui(result);\n      // renderTui sets up the blessed event loop; process stays alive until 'q'\n    } else {\n      const json = JSON.stringify(result, null, 2);\n      if (opts.output) {\n        fs.writeFileSync(opts.output, json, 'utf8');\n        console.error(`Layout written to ${opts.output}`);\n      } else {\n        process.stdout.write(json + '\\n');\n      }\n    }\n  } finally {\n    await browser.close();\n  }\n}\n\nmain().catch((err) => {\n  console.error(`Unexpected error: ${err.message}`);\n  process.exit(3);\n});\n","numLines":609,"startLine":1,"totalLines":609}}}
